# Redis Connection URL (pointing to the same Redis instance as MS1)
REDIS_URL="redis://localhost:6379/0"

# PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resumeproof?schema=public"

# Third-party API keys
GROQ_API_KEY="gsk_..."
GITHUB_TOKEN="ghp_..."

# Secret shared between MS1 and MS2 for internal calls
INTERNAL_SECRET="some_long_internal_shared_secret"

# Internal URL of MS1 Orchestrator
MS1_INTERNAL_URL="http://localhost:3001"

# Port to run MS2 on
MS2_PORT=3002
